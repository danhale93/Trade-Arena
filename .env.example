# ════════════════════════════════════════════════════════════════════════════════
# TRADE ARENA v2.0 - Environment Configuration
# ════════════════════════════════════════════════════════════════════════════════

# ── Alpaca Trading API ──
# Get your keys at: https://alpaca.markets/
ALPACA_KEY=your_alpaca_api_key_here
ALPACA_SECRET=your_alpaca_secret_key_here

# ── Anthropic Claude AI ──
# Get your API key at: https://console.anthropic.com/
ANTHROPIC_KEY=your_anthropic_api_key_here

# ── MongoDB Database ──
# Optional: For bot/trade persistence. Leave empty to run without DB.
# Free tier at: https://www.mongodb.com/atlas
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/trade-arena?retryWrites=true&w=majority

# ── Server Configuration ──
PORT=3001
NODE_ENV=development

# ── WebSocket Configuration ──
WS_HEARTBEAT_INTERVAL=30000
WS_MAX_CONNECTIONS=100

# ── MCP Server Configuration ──
MCP_SERVER_NAME=trade-arena-mcp
MCP_CACHE_TTL_MS=30000
MCP_MAX_BOTS_PER_USER=20

# ── Trading Configuration ──
DEFAULT_INITIAL_CAPITAL=1000
DEFAULT_RISK_LEVEL=MODERATE
PAPER_TRADING_DEFAULT=true

# ── CoinGecko API (Free, no key needed for basic usage) ──
# Optional: For higher rate limits
COINGECKO_API_KEY=

# ── Security ──
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
JWT_EXPIRES_IN=7d

# ── Rate Limiting ──
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
