# Render Environment Variables Example
# Copy this to .env for local development

PORT=3001

# AI API Keys
ANTHROPIC_API_KEY=your_anthropic_api_key_here
OPENAI_API_KEY=your_openai_api_key_here
GEMINI_API_KEY=your_gemini_api_key_here

# MoonPay Configuration
MOONPAY_WEBHOOK_SECRET=your_moonpay_webhook_secret_here

# Network Configuration
RPC_URL=https://mainnet.base.org
BASE_SEPOLIA_RPC_URL=https://sepolia.base.org
CHAIN_CURRENCY=ETH

# PRIVY & MOONPAY
PRIVY_APP_ID=cmpl1hc0k00ui0djsr3qo8gg8
MOONPAY_PUBLIC_KEY=pk_test_5rdSBYM23wRwK1L3icX9RqYdypJ6jGEC

# OAUTH
GOOGLE_CLIENT_ID=

# TRADING PARAMETERS
INITIAL_BALANCE=0
MIN_BET=1
MAX_BET=500
MAX_BOTS=6
TASK_CLAIM_SECRET=your_secret_here
AUTO_SPIN_DELAY_MIN=3000
AUTO_SPIN_DELAY_MAX=8000

# STRATEGY SETTINGS
WIN_PROBABILITY_BASE=0.55
EDGE_PCT_MIN=0.5
EDGE_PCT_MAX=8.5
PNL_MULTIPLIER_WIN_MIN=0.5
PNL_MULTIPLIER_WIN_MAX=3.5
PNL_MULTIPLIER_LOSS_MIN=-0.9
PNL_MULTIPLIER_LOSS_MAX=-0.2

# MARKET DATA
MARKET_DATA_ENDPOINT=https://api.coingecko.com/api/v3/coins/markets
MARKET_CACHE_TTL=30000
TOP_MARKETS_COUNT=30

# LOGGING
LOG_TRADES=true
LOG_LEVEL=info
MAX_LOG_ENTRIES=30

# FEATURES
ENABLE_PARTICLES=true
ENABLE_SOUND=false
ENABLE_NOTIFICATIONS=true
THEME=dark

# ALLOWED_ORIGIN (CORS)
ALLOWED_ORIGIN=
