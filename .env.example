# Supabase Configuration
# 1. Create free project at https://supabase.com/dashboard
# 2. Settings → API → copy URL + anon key here
# 3. Rename to .env (gitignored) and fill real values
# 4. npm install @supabase/supabase-js

VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Base Network (optional - for server-side RPC)
VITE_BASE_RPC=https://mainnet.base.org

# Anthropic API (existing)
ANTHROPIC_API_KEY=sk-ant-...

# Gitignore: add .env to .gitignore if missing

