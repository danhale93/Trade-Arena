{
  "name": "trade-arena",
  "version": "4.0.0",
  "description": "Multi-AI Trading Arena with Ridges Integration",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "node server.js",
    "test": "node tests.js",
    "proxy": "node proxy.js",
    "serve": "npx serve .",
    "build": "esbuild public/src/main.tsx --bundle --outfile=public/arena-react-bundle.js --minify --sourcemap --loader:.tsx=tsx --loader:.jsx=jsx",
    "postinstall": "npm run build"
  },
  "dependencies": {
    "@biconomy/abstractjs": "^1.2.5",
    "@biconomy/account": "^4.5.7",
    "@privy-io/react-auth": "^3.35.1",
    "axios": "1.18.1",
    "ccxt": "^4.5.64",
    "cors": "^2.8.5",
    "dotenv": "17.4.2",
    "ethers": "6.17.0",
    "express": "5.2.1",
    "express-rate-limit": "^8.5.2",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "viem": "^2.55.1",
    "websocket": "^1.0.35",
    "zod": "3.25.76"
  },
  "devDependencies": {
    "esbuild": "^0.28.1",
    "concurrently": "^10.0.3",
    "playwright": "^1.61.1"
  }
}