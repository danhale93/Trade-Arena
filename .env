# ═══════════════════════════════════════════════════════
# TRADE ARENA v4 • Configuration
# ═══════════════════════════════════════════════════════

# ─── BLOCKCHAIN ───
NETWORK=base
NETWORK_ID=8453
RPC_URL=https://mainnet.base.org
CHAIN_CURRENCY=ETH

# ─── AI INTEGRATION ───
# Get your API key from https://console.anthropic.com/
ANTHROPIC_API_KEY=sk_YOUR_KEY_HERE

# ─── OAUTH ───
# Google OAuth for sign-in
# Get Client ID from https://console.cloud.google.com/
GOOGLE_CLIENT_ID=YOUR_GOOGLE_CLIENT_ID.apps.googleusercontent.com

# ─── TRADING PARAMETERS ───
INITIAL_BALANCE=10000
MIN_BET=1
MAX_BET=500
MAX_BOTS=6
AUTO_SPIN_DELAY_MIN=3000
AUTO_SPIN_DELAY_MAX=8000

# ─── STRATEGY SETTINGS ───
WIN_PROBABILITY_BASE=0.55
EDGE_PCT_MIN=0.5
EDGE_PCT_MAX=8.5
PNL_MULTIPLIER_WIN_MIN=0.5
PNL_MULTIPLIER_WIN_MAX=3.5
PNL_MULTIPLIER_LOSS_MIN=-0.9
PNL_MULTIPLIER_LOSS_MAX=-0.2

# ─── MARKET DATA ───
# CoinGecko API (free, no key required)
MARKET_DATA_ENDPOINT=https://api.coingecko.com/api/v3/coins/markets
MARKET_CACHE_TTL=30000
TOP_MARKETS_COUNT=30

# ─── LOGGING ───
LOG_TRADES=true
LOG_LEVEL=info
MAX_LOG_ENTRIES=30

# ─── FEATURES ───
ENABLE_PARTICLES=true
ENABLE_SOUND=false
ENABLE_NOTIFICATIONS=true
THEME=dark

# ─── LEGACY (deprecated, kept for compatibility) ───
FLASH_LOAN_ADDRESS=0x794a61358D6845594F94dc1DB02A252b5b4814aD
DEX_ROUTER_ADDRESS=0x68b3465833fb72B5A828cCEA02FFAD6bCFB8ACBA
USDC_ADDRESS=0x833589fCD6eDb6E08f4c7C32D4f71b54bdA02913
WETH_ADDRESS=0x4200000000000000000000000000000000000006
